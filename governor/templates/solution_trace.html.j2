<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solution Trace · {{ session.topic | truncate(40) }}</title>
<style>
  :root {
    --bg: #f8fafc; --surface: #fff; --border: #e2e8f0;
    --cyan: #0891b2; --cyan-bg: #ecfeff; --cyan-border: #a5f3fc;
    --purple: #7c3aed; --purple-bg: #f5f3ff; --purple-border: #ddd6fe;
    --amber: #d97706; --amber-bg: #fffbeb; --amber-border: #fde68a;
    --rose: #e11d48; --rose-bg: #fff1f2; --rose-border: #fecdd3;
    --emerald: #059669; --emerald-bg: #ecfdf5; --emerald-border: #a7f3d0;
    --muted: #64748b; --text: #1e293b; --mono: 'Courier New', monospace;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: 'Helvetica Neue', Arial, sans-serif; background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.7; }
  @media print { .page-break { page-break-before: always; } }

  .page { max-width: 1000px; margin: 0 auto; padding: 48px 40px; }
  .page + .page { border-top: 3px dashed var(--border); padding-top: 60px; }

  .cover { border-bottom: 3px solid var(--cyan); padding-bottom: 28px; margin-bottom: 36px; }
  .cover-type { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--cyan); margin-bottom: 8px; }
  .cover-title { font-size: 26px; font-weight: 800; color: var(--text); margin-bottom: 12px; }
  .cover-meta { display: flex; gap: 20px; flex-wrap: wrap; font-size: 12px; color: var(--muted); }
  .cover-meta strong { color: var(--text); }
  .session-id { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 8px; }

  /* Timeline */
  .timeline { position: relative; padding-left: 24px; }
  .timeline::before { content:''; position:absolute; left:8px; top:0; bottom:0; width:2px; background:var(--border); }
  .tl-item { position: relative; margin-bottom: 20px; }
  .tl-dot {
    position: absolute; left: -24px; top: 14px;
    width: 14px; height: 14px; border-radius: 50%;
    border: 2px solid var(--border); background: var(--surface);
  }
  .tl-dot.dot-hypothesis { border-color: var(--amber); background: var(--amber-bg); }
  .tl-dot.dot-gitnexus_audit { border-color: var(--cyan); background: var(--cyan-bg); }
  .tl-dot.dot-tradeoff { border-color: var(--purple); background: var(--purple-bg); }
  .tl-dot.dot-pain_point { border-color: var(--rose); background: var(--rose-bg); }

  .tl-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 14px 16px;
  }
  .tl-header { display: flex; gap: 10px; align-items: center; margin-bottom: 8px; flex-wrap: wrap; }
  .tl-stage {
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 2px 8px; border-radius: 4px;
  }
  .stage-hypothesis .tl-stage { background: var(--amber-bg); color: var(--amber); }
  .stage-gitnexus_audit .tl-stage { background: var(--cyan-bg); color: var(--cyan); }
  .stage-tradeoff .tl-stage { background: var(--purple-bg); color: var(--purple); }
  .stage-pain_point .tl-stage { background: var(--rose-bg); color: var(--rose); }
  .stage-next_session .tl-stage { background: #f0fdf4; color: var(--emerald); }

  .tl-role { font-size: 11px; color: var(--muted); }
  .tl-time { font-size: 11px; color: var(--muted); font-family: var(--mono); }
  .tl-hash { font-size: 10px; color: #94a3b8; font-family: var(--mono); }
  .tl-content { font-size: 13px; white-space: pre-wrap; word-break: break-word; }

  /* Section */
  .section { margin-bottom: 36px; }
  .section-title {
    font-size: 13px; font-weight: 700; color: var(--muted); text-transform: uppercase;
    letter-spacing: 0.1em; border-bottom: 1px solid var(--border);
    padding-bottom: 8px; margin-bottom: 16px;
  }

  /* Pain point & Next session */
  .pain-card {
    background: var(--rose-bg); border: 1px solid var(--rose-border);
    border-radius: 8px; padding: 14px 16px; margin-bottom: 10px;
  }
  .pain-card p { color: #9f1239; font-size: 13px; }

  .next-card {
    background: var(--emerald-bg); border: 1px solid var(--emerald-border);
    border-radius: 8px; padding: 14px 16px; margin-bottom: 10px;
  }
  .next-card p { color: #065f46; font-size: 13px; }

  /* Stage Gate status */
  .gate-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
  .gate-card {
    border-radius: 8px; padding: 14px 16px; text-align: center;
    border: 1px solid var(--border);
  }
  .gate-card.passed { background: var(--emerald-bg); border-color: var(--emerald-border); }
  .gate-card.blocked { background: var(--rose-bg); border-color: var(--rose-border); }
  .gate-card.pending { background: #f8fafc; }
  .gate-label { font-size: 11px; color: var(--muted); margin-bottom: 4px; }
  .gate-status { font-size: 16px; font-weight: 800; }
  .passed .gate-status { color: var(--emerald); }
  .blocked .gate-status { color: var(--rose); }
  .pending .gate-status { color: var(--muted); }

  .pending { color: var(--rose); font-style: italic; font-size: 13px; }

  .footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--border); text-align: center; font-size: 11px; color: var(--muted); }
</style>
</head>
<body>

<!-- PAGE 1: Problem → Hypothesis → Verification → Solution -->
<div class="page">
  <div class="cover">
    <div class="cover-type">🔬 Solution Trace · System Governor</div>
    <div class="cover-title">{{ session.topic }}</div>
    <div class="cover-meta">
      <span><strong>Page 1/2</strong> — 問題定義 → 假設 → 求證 → 解法</span>
      <span>{{ generated_at }}</span>
      <span>記錄數: {{ all_records | length }}</span>
    </div>
    <div class="session-id">Session: {{ session_id }}</div>
  </div>

  <!-- Stage Gate summary -->
  <div class="section">
    <div class="section-title">工作流通關狀態</div>
    <div class="gate-row">
      {% for s, label in [('01','假設對齊'),('02','GitNexus 剖析'),('03','架構辯證')] %}
      {% set sp = [stage_01, stage_02, stage_03][loop.index0] %}
      <div class="gate-card {{ sp.status if sp else 'pending' }}">
        <div class="gate-label">Stage {{ s }} · {{ label }}</div>
        <div class="gate-status">
          {% if not sp %}⏳ Pending{% elif sp.status == 'passed' %}✅ Passed{% elif sp.status == 'blocked' %}🚫 Blocked{% else %}{{ sp.status }}{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Problem definition -->
  <div class="section">
    <div class="section-title">§1 問題定義（訪談原始記錄）</div>
    {% set interview_records = by_stage.get('interview', []) %}
    {% if interview_records %}
      <div class="timeline">
        {% for r in interview_records %}
        <div class="tl-item stage-interview">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-header">
              <span class="tl-role">{{ r.role }}</span>
              <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
              <span class="tl-hash">#{{ r.sha256_hash[:8] if r.sha256_hash else '' }}</span>
            </div>
            <div class="tl-content">{{ r.content }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="pending">【⏳ 訪談記錄 待確認】</p>
    {% endif %}
  </div>

  <!-- Hypothesis -->
  <div class="section">
    <div class="section-title">§2 假設對齊討論</div>
    {% set hyp_records = by_stage.get('hypothesis', []) %}
    {% if hyp_records %}
      <div class="timeline">
        {% for r in hyp_records %}
        <div class="tl-item stage-hypothesis">
          <div class="tl-dot dot-hypothesis"></div>
          <div class="tl-card">
            <div class="tl-header">
              <span class="tl-stage">hypothesis</span>
              <span class="tl-role">{{ r.role }}</span>
              <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
            </div>
            <div class="tl-content">{{ r.content }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="pending">【⏳ 假設對齊討論 待確認】</p>
    {% endif %}
  </div>

  <!-- GitNexus verification -->
  <div class="section">
    <div class="section-title">§3 GitNexus 求證</div>
    {% set audit_records = by_stage.get('gitnexus_audit', []) %}
    {% if audit_records %}
      <div class="timeline">
        {% for r in audit_records %}
        <div class="tl-item stage-gitnexus_audit">
          <div class="tl-dot dot-gitnexus_audit"></div>
          <div class="tl-card">
            <div class="tl-header">
              <span class="tl-stage">gitnexus</span>
              <span class="tl-role">{{ r.role }}</span>
              <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
            </div>
            <div class="tl-content">{{ r.content }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="pending">【⏳ GitNexus 圖譜求證 待確認】</p>
    {% endif %}
  </div>

  <!-- Solution / Tradeoff -->
  <div class="section">
    <div class="section-title">§4 解決方案 / 架構辯證</div>
    {% set trade_records = by_stage.get('tradeoff', []) %}
    {% if trade_records %}
      <div class="timeline">
        {% for r in trade_records %}
        <div class="tl-item stage-tradeoff">
          <div class="tl-dot dot-tradeoff"></div>
          <div class="tl-card">
            <div class="tl-header">
              <span class="tl-stage">tradeoff</span>
              <span class="tl-role">{{ r.role }}</span>
              <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
            </div>
            <div class="tl-content">{{ r.content }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="pending">【⏳ 架構辯證討論 待確認】</p>
    {% endif %}
  </div>

  <div class="footer">Page 1/2 · Solution Trace · {{ generated_at }} · Session: {{ session_id }}</div>
</div>

<!-- PAGE 2: Pain Points / Clarification / Next Session -->
<div class="page page-break">
  <div class="cover" style="border-color: var(--rose);">
    <div class="cover-type" style="color: var(--rose);">📋 Solution Trace · Page 2/2</div>
    <div class="cover-title">疑惑釐清 / 痛點 / 下次待解決</div>
    <div class="cover-meta"><span>{{ generated_at }}</span></div>
    <div class="session-id">Session: {{ session_id }}</div>
  </div>

  <!-- Clarification / Doubt -->
  <div class="section">
    <div class="section-title">§5 疑惑釐清記錄（原始提問與回覆）</div>
    {% set interview_q = by_stage.get('interview', []) | selectattr('source_note', 'ne', None) | list %}
    {% if by_stage.get('interview') %}
      <div class="timeline">
        {% for r in by_stage.get('interview', []) %}
        {% if r.source_note and ('疑' in r.source_note or '問' in r.source_note or '確認' in r.source_note or '釐清' in r.source_note) %}
        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-header">
              <span class="tl-role">{{ r.role }}</span>
              <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
            </div>
            <div class="tl-content">{{ r.content }}</div>
            <div style="font-size:11px;color:var(--muted);margin-top:6px;">📌 {{ r.source_note }}</div>
          </div>
        </div>
        {% endif %}
        {% endfor %}
      </div>
      <p style="color:var(--muted);font-size:12px;margin-top:8px;">（所有 source_note 含「疑」「問」「確認」「釐清」的記錄）</p>
    {% else %}
      <p class="pending">【⏳ 疑惑釐清 待確認】</p>
    {% endif %}
  </div>

  <!-- Pain Points -->
  <div class="section">
    <div class="section-title">§6 目前痛點</div>
    {% set pain_records = by_stage.get('pain_point', []) %}
    {% if pain_records %}
      {% for r in pain_records %}
      <div class="pain-card">
        <p>{{ r.content }}</p>
        <div style="font-size:11px;color:#9f1239;margin-top:6px;">— {{ r.role }} · {{ r.created_at[:10] }}</div>
      </div>
      {% endfor %}
    {% else %}
      <p class="pending">【⏳ 痛點記錄 待確認 — 呼叫 sg_record_input(stage='pain_point')】</p>
    {% endif %}
  </div>

  <!-- Next Session -->
  <div class="section">
    <div class="section-title">§7 下次待解決事項</div>
    {% set next_records = by_stage.get('next_session', []) %}
    {% if next_records %}
      {% for r in next_records %}
      <div class="next-card">
        <p>{{ r.content }}</p>
        <div style="font-size:11px;color:#065f46;margin-top:6px;">— {{ r.role }} · {{ r.created_at[:10] }}</div>
      </div>
      {% endfor %}
    {% else %}
      <p class="pending">【⏳ 下次待解決事項 待確認 — 呼叫 sg_record_input(stage='next_session')】</p>
    {% endif %}
  </div>

  <!-- Thinking Timeline (all stages chronological) -->
  <div class="section">
    <div class="section-title">§8 完整思考時間軸</div>
    {% if all_records %}
    <div class="timeline">
      {% for r in all_records %}
      <div class="tl-item stage-{{ r.stage }}">
        <div class="tl-dot dot-{{ r.stage }}"></div>
        <div class="tl-card">
          <div class="tl-header">
            <span class="tl-stage">{{ r.stage }}</span>
            <span class="tl-role">{{ r.role }}</span>
            <span class="tl-time">{{ r.created_at[:19].replace('T',' ') }}</span>
            <span class="tl-hash">#{{ r.sha256_hash[:8] if r.sha256_hash else '' }}</span>
          </div>
          <div class="tl-content" style="font-size:12px;">{{ r.content | truncate(200) }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
      <p class="pending">【⏳ 尚無任何記錄】</p>
    {% endif %}
  </div>

  <div class="footer">Page 2/2 · Solution Trace · {{ generated_at }} · Session: {{ session_id }}<br>⚠️ 本報告內容完全來自 sg_record_input 記錄，系統未做任何推導補全。</div>
</div>

</body>
</html>
