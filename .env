# System Governor MCP — Docker 環境配置
# 本檔案包含所有 Docker 容器運行所需的環境變數

# ============================================================
# 網絡配置
# ============================================================
MCP_HOST=0.0.0.0
MCP_PORT=9090

# ============================================================
# 數據存儲
# ============================================================
DATA_DIR=/data
DB_PATH=/data/governor.db
REPORTS_DIR=/data/reports

# ============================================================
# 業務邏輯
# ============================================================
REMINDER_THRESHOLD_MINUTES=10
