# System Governor MCP — Docker 環境變數配置
# 複製此檔為 .env 並根據需要修改

# ============================================================
# 網絡配置 (MCP Service)
# ============================================================

# MCP 服務綁定的主機地址
# - 0.0.0.0: 允許外部連接（Docker 內部推薦）
# - 127.0.0.1: 僅本機連接
# - 特定 IP: 綁定到特定網卡
MCP_HOST=0.0.0.0

# MCP HTTP/SSE 服務監聽端口
# ⚠️ 務必避免與其他服務衝突
# 常用備選端口: 9090, 9091, 8081, 8888, 3000
# 推薦: 9090 (冷門，不與常見服務衝突)
MCP_PORT=9090

# ============================================================
# 數據存儲配置
# ============================================================

# 根資料目錄（Docker 內部）
# 預設綁定: ./data:/data (本機 data 目錄掛載到容器 /data)
DATA_DIR=/data

# SQLite 資料庫檔案路徑
# 須位於 Docker Volume 內以確保持久化
# 如無特殊需求，保持預設值
DB_PATH=/data/governor.db

# 報告輸出目錄（HTML 報告、JSON、Hash Chain）
# 須位於 Docker Volume 內以確保報告不丟失
REPORTS_DIR=/data/reports

# ============================================================
# 業務邏輯配置
# ============================================================

# Reminder 提醒門檻（分鐘）
# 若超過此時間沒有新的 sg_record_input，系統會標記 【⏳ 待確認】
# 建議值: 10-60 分鐘
REMINDER_THRESHOLD_MINUTES=10

# ============================================================
# Docker Compose 配置備註
# ============================================================

# 當前 docker-compose.yml 映射:
#   Port:   8080:9090    (本機:容器)
#   Volume: ./data:/data  (本機目錄:容器掛載點)
#
# 修改步驟:
# 1. 編輯本檔案 (.env)
# 2. 執行: docker-compose down
# 3. 執行: docker-compose up -d
# 4. 驗證: curl http://localhost:9090/health

# ============================================================
# Docker 運行檢查清單
# ============================================================

# ✅ 數據持久化驗證
#   docker exec system-governor-mcp ls -la /data/
#   → 應該看到 governor.db 和 reports/ 目錄
#
# ✅ 健康檢查驗證
#   curl http://localhost:9090/health
#   → 應返回 JSON: {"status":"ok","service":"system-governor-mcp","tools":15}
#
# ✅ 容器重啟驗證 (確保數據不丟失)
#   docker-compose restart system-governor-mcp
#   docker exec system-governor-mcp sqlite3 /data/governor.db "SELECT COUNT(*) FROM sessions;"
#   → 應返回舊數據的 session 計數
#
# ✅ 日誌監控
#   docker-compose logs -f system-governor-mcp
#   → 監視服務啟動和運行狀態

# ============================================================
# 常見問題與解決
# ============================================================

# Q: 修改 MCP_PORT 後連接失敗？
# A: 確認已在 docker-compose.yml 中同步修改埠號映射
#    ports: "LOCAL_PORT:9090"  (其中 9090 應與 MCP_PORT 一致)
#
# Q: 報告生成後找不到檔案？
# A: 檢查本機 ./data/reports/ 目錄是否有對應的 HTML 檔
#    若找不到，檢查 REPORTS_DIR 環境變數是否正確
#
# Q: Docker 重啟後資料遺失？
# A: 檢查 docker-compose.yml volumes 配置:
#    volumes:
#      - ./data:/data  ← 須指向本機的 data 目錄
#
# Q: 多個開發者共用同一個資料庫？
# A: 改用遠端 PostgreSQL (需修改 core/db.py)
#    當前 SQLite 設計只支援單機
